# LoopLearn WhatsApp Bot — Environment Variables
# Copy this to .env and fill in the values

# Your deployed LoopLearnX URL (no trailing slash)
LOOPLEARN_API_URL=https://your-app.vercel.app

# Shared secret between VPS and Next.js — generate with: openssl rand -hex 32
WHATSAPP_BOT_SECRET=your_secret_here

# Your personal WhatsApp number (with country code, no +)
# Example: 919876543210
TEACHER_WHATSAPP_PHONE=91XXXXXXXXXX
